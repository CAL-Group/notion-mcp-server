{
  "name": "notion-mcp-server",
  "version": "1.0.0",
  "description": "Official Notion MCP Server wrapped for Google Cloud Run",
  "private": true,
  "scripts": {
    "start": "supergateway --stdio \"npx -y @notionhq/notion-mcp-server\" --port 8080 --outputTransport streamableHttp --streamableHttpPath /mcp"
  },
  "dependencies": {
    "@notionhq/notion-mcp-server": "latest",
    "supergateway": "latest"
  }
}
